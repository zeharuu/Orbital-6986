rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Food items are public read-only data, seeded by an admin script.
    match /foodItems/{itemId} {
      allow read: if true;
      allow write: if false;
    }

    // Users can only read/write their own profile/log/streak document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
